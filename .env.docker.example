# Copy to .env.docker before starting Docker:
#   copy .env.docker.example .env.docker
#
# Local development — mirrors .env local settings.
# DB_HOST must be "mysql" (Docker service name), not 127.0.0.1.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://192.168.1.16:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (Docker creates this MySQL instance on first run)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=compay
DB_USERNAME=root
DB_PASSWORD=your_local_db_password

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,192.168.1.16:8000,192.168.1.16:8081

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_SCHEME=http
PUSHER_PORT=80

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Firebase (optional, for push notifications)
# FIREBASE_PROJECT_ID=
# FIREBASE_CREDENTIALS=/var/www/html/storage/app/firebase-credentials.json

# Ports exposed on the host (used by docker-compose)
APP_PORT=8000
DB_FORWARD_PORT=3307
PHPMYADMIN_PORT=8080
VITE_PORT=5173

# Automatic startup
RUN_MIGRATIONS=true
RUN_SEEDERS=false
